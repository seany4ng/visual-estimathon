{
  "name": "visual-games-workspace",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "estimathon-suite",
    "angle-battles"
  ],
  "scripts": {
    "dev:visual": "npm --workspace visual-estimathon run dev",
    "dev:angles": "npm --workspace angle-battles run dev",
    "serve:angles-server": "npm --workspace angle-battles run serve:server",
    "deploy:angles-server": "npm --workspace angle-battles run deploy:server",
    "build": "npm --workspaces run build",
    "build:visual": "npm --workspace visual-estimathon run build",
    "build:angles": "npm --workspace angle-battles run build"
  }
}
